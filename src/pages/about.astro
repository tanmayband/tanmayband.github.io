---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import tanmay from '@media/tanmay2.jpg';
---

<BaseLayout title="About | Tanmay Band" description="About Tanmay Band Lorem Ipsum">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About"
				tagline="Thanks for stopping by!"
			>
				<Image
					height={500}
					src={tanmay}
					alt="Tanmay Band at work with a colleague"
					style="margin: auto"
				/>
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						Me guy like cool stuf
					</p>
					<br/>
					<p>
						Me guy maek cool stuf
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<p>Bachelor of Technology (B. Tech) in Computer Science & Engineering</p>
					<p class="institute">Visvesvaraya National Institute of Technology (2013 - 2017)</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Toolkit</h2>
				<div class="content">
					<p><strong>Engines:</strong> Unreal Engine 5, Unity, Unreal Engine for Fortnite (UEFN)</p>
					<p><strong>Languages:</strong> Unreal Blueprints, C++, C#, Verse, Node.js, Python</p>
					<p><strong>Server:</strong> AWS</p>
					<p><strong>CI/CD:</strong> Jenkins, GitHub Actions</p>
					<p><strong>Creative:</strong> Blender, Krita, Inkscape</p>
					<p><strong>Documentation:</strong> Markdown, Obsidian</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content">
					<ul>
						<li>Plug-and-play systems</li>
						<li>Scalable architecture</li>
						<li>Clear documentation</li>
						<li>Cross-functional collaboration</li>
						<li>Player experience intuition</li>
					</ul>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
	
	.institute {
		font-style: italic;
	}
</style>
