---
import ContentWithCaption from './ContentWithCaption.astro'

interface Props {
  id: string;
  caption?: string;
}

const { id, caption = "YouTube video" } = Astro.props;
---

<ContentWithCaption caption={caption}>
  <div slot="content" class="video">
    <iframe
    src={`https://www.youtube.com/embed/${id}`}
    title={caption}
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen>
  </iframe>
  </div>
</ContentWithCaption>

<style>
.video {
  aspect-ratio: 16 / 9;
}

.video iframe {
  width: 100%;
  height: 100%;
  border: 0;
}
</style>