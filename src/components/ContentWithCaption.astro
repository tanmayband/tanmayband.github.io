---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
	src?: string | ImageMetadata;
	caption: string;
	width?: number;
	height?: number;
	class?: string;
}

const { src, caption = "", width, height } = Astro.props as Props;
const hasContentSlot = Astro.slots.has("content");
const figureStyle = width ? `max-width: ${width};` : undefined;

if (!src && !hasContentSlot) {
    throw new Error("ContentWithCaption: provide either `src` or a `slot=\"mcontenta\"` element.");
}

if (typeof src === "string") {
	if (typeof width !== "number" || typeof height !== "number") {
		throw new Error(
			"ContentWithCaption: when src is a string you must pass numeric width and height, or pass an imported ImageMetadata object.",
		);
	}
}
---

<figure class="img-caption-container rounded-box" style={figureStyle}>
	{
		src ? (
            typeof src === "string" ? (
                <Image src={src} alt={caption} width={width!} height={height!} />
            ) : (
                <Image src={src} alt={caption} />
            )
        ) : (
            <slot name="content"/>
        )
	}
	{caption && <figcaption class="caption">{caption}</figcaption>}
</figure>

<style>
	.img-caption-container {
		margin-bottom: 1rem;
		background: var(--gradient-subtle);
		margin-left: auto;
		margin-right: auto;

		img {
			border-radius: initial;
			border: none;
		}
	
		.caption {
			text-align: center;
			color: var(--accent-dark);
			margin: 0.5rem;
			font-size: var(--text-base);
		}
	}
</style>
